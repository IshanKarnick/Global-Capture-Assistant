<Window x:Class="GlobalCaptureAssistant.Capture.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#660A0D12"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Grid>
        <Canvas>
            <Rectangle Name="SelectionRectVisual"
                       Stroke="#FFE8F4FF"
                       StrokeThickness="2"
                       Fill="#3342B3F5"
                       Visibility="Collapsed" />
            <Border Name="HintCard"
                    Canvas.Left="28"
                    Canvas.Top="24"
                    CornerRadius="12"
                    Padding="12,8"
                    Background="#AA172131">
                <TextBlock Name="HintText"
                           Foreground="#FFF5F9FF"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="14"
                           Text="Drag to select. Enter confirms, Esc cancels." />
            </Border>
        </Canvas>
    </Grid>
</Window>
