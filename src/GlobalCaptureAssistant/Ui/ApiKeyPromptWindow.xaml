<Window x:Class="GlobalCaptureAssistant.Ui.ApiKeyPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini API Key"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text">

    <!-- Shell — DWM handles blur, rounding, and shadow -->
    <Border MinWidth="400"
            Padding="20,16"
            Background="#55ECF0F4"
            BorderBrush="#25AAAAAA"
            BorderThickness="1">

        <StackPanel>
            <!-- Title bar row -->
            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Gemini API Key"
                               Foreground="#DD1A1A1A"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Required to use AI capture features"
                               Foreground="#88000000"
                               FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="26"
                        Height="22"
                        Padding="0"
                        FontSize="13"
                        Content="✕"
                        VerticalAlignment="Top"
                        Foreground="#99000000"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close"
                        Click="CloseButton_Click" />
            </Grid>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22000000" Margin="0,0,0,14" />

            <!-- Input label -->
            <TextBlock Text="API KEY"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#88000000"
                       Margin="0,0,0,5" />

            <PasswordBox x:Name="ApiKeyInput"
                         MinWidth="360"
                         Padding="10,7"
                         FontSize="13"
                         BorderBrush="#55BBBBBB"
                         BorderThickness="1" />

            <!-- Helper text -->
            <TextBlock Margin="0,8,0,0"
                       FontSize="12"
                       Foreground="#88000000"
                       Text="Stored locally with Windows DPAPI encryption." />

            <!-- Action buttons -->
            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        Padding="0,7"
                        IsCancel="True"
                        Cursor="Hand" />
                <Button Content="Save"
                        MinWidth="80"
                        Padding="0,7"
                        IsDefault="True"
                        Cursor="Hand"
                        Click="SaveButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
