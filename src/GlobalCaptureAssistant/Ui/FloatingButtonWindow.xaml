<Window x:Class="GlobalCaptureAssistant.Ui.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="64"
        Height="64"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0.92" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.10" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                             To="1.07"
                                             Duration="0:0:0.10" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                             To="1.07"
                                             Duration="0:0:0.10" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.92"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- pill badge — CornerRadius gives the pill shape inside the window -->
        <Border x:Name="RootBadge"
                Style="{StaticResource BadgeStyle}"
                CornerRadius="32"
                Background="#55DDE8EE"
                BorderBrush="#25AAAAAA"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12"
                                  ShadowDepth="0"
                                  Color="#55000000"
                                  Opacity="0.3" />
            </Border.Effect>

            <Button x:Name="CaptureButton"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Capture screen region">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Camera-style icon using text -->
                    <TextBlock Text="⬡"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Foreground="#99000000" />
                    <TextBlock Text="CAP"
                               FontFamily="Segoe UI Variable Text"
                               FontWeight="SemiBold"
                               FontSize="9"
                               HorizontalAlignment="Center"
                               Foreground="#BB1A1A1A"
                               Margin="0,-4,0,0" />
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</Window>
