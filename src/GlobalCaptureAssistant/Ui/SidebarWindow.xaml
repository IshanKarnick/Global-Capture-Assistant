<Window x:Class="GlobalCaptureAssistant.Ui.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GlobalCaptureAssistant.Ui.Converters"
        xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
        xmlns:local="clr-namespace:GlobalCaptureAssistant.Ui"
        Title="Capture Assistant"
        Icon="pack://application:,,,/Assets/Icons/app.png"
        Width="420"
        Height="720"
        MinWidth="360"
        MinHeight="480"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        FontFamily="Segoe UI Variable Text">
    <WindowChrome.WindowChrome>
        <!-- Left/Right = 0 (no horizontal resize), Top/Bottom = 6 (vertical resize grip) -->
        <WindowChrome ResizeBorderThickness="0,6,0,6"
                      CaptionHeight="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Light frosted-glass shell gradient -->
        <LinearGradientBrush x:Key="ShellGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A0EEF2F6" Offset="0" />
            <GradientStop Color="#90E4EBF0" Offset="1" />
        </LinearGradientBrush>

        <!-- Section divider -->
        <Style x:Key="Divider" TargetType="Rectangle">
            <Setter Property="Height" Value="1" />
            <Setter Property="Fill" Value="#22000000" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <!-- Section label (e.g. "MODEL", "CONTEXT") -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#88000000" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <!-- Card surface -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderBrush" Value="#44BBBBBB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.20" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Window chrome buttons (minimize / close) -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#AA000000" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF1A1A1A" />
            <Setter Property="Background" Value="#44AABBCC" />
            <Setter Property="BorderBrush" Value="#55AABBCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#66AABBCC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#88AABBCC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Shell — DWM handles blur, rounding, and shadow -->
    <Border Background="#11EEF0F2"
            BorderBrush="#25AAAAAA"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="48" />
                <!-- Scrollable content -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0"
                    Padding="16,0,10,0"
                    Background="#11000000"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Capture Assistant"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#DD1A1A1A"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="·"
                                   Margin="8,0"
                                   FontSize="14"
                                   Foreground="#66000000"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="#88000000"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,2,0">

                        <!-- ⚙ Settings button -->
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource ChromeButton}"
                                Content="⚙"
                                FontSize="15"
                                ToolTip="Settings"
                                Click="SettingsButton_Click" />

                        <Popup x:Name="SettingsPopup"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=SettingsButton}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border CornerRadius="10"
                                    Padding="14,12"
                                    Background="#EAF0F4F8"
                                    BorderBrush="#33AAAAAA"
                                    BorderThickness="1"
                                    MinWidth="280">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#55000000" Opacity="0.3" />
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Model -->
                                    <TextBlock Text="MODEL" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Margin="0,0,0,10"
                                              ItemsSource="{Binding ModelOptions}"
                                              SelectedItem="{Binding SelectedModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!-- Thinking -->
                                    <TextBlock Text="THINKING" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Margin="0,0,0,10"
                                              ItemsSource="{Binding ThinkingOptions}"
                                              SelectedItem="{Binding SelectedThinkingLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!-- Startup -->
                                    <TextBlock Text="STARTUP" Style="{StaticResource SectionLabel}" />
                                    <CheckBox Content="Launch on sign-in"
                                              IsChecked="{Binding AutoStartEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Foreground="#CC1A1A1A"
                                              Margin="0,0,0,10" />

                                    <!-- Hotkey (read-only) -->
                                    <TextBlock Text="HOTKEY" Style="{StaticResource SectionLabel}" />
                                    <Border Background="#22000000" CornerRadius="5" Padding="8,4" HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Shift + Q"
                                                   FontSize="12"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   Foreground="#CC1A1A1A" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button Style="{StaticResource ChromeButton}"
                                Margin="2,0,0,0"
                                Content="−"
                                ToolTip="Minimize"
                                Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource ChromeButton}"
                                Margin="2,0,0,0"
                                Content="✕"
                                ToolTip="Hide"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable body ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="14,10,14,14">
                <StackPanel>

                    <!-- Context card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CONTEXT" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="{Binding ContextText}"
                                       FontSize="13"
                                       Foreground="#CC1A1A1A"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </StackPanel>
                    </Border>

                    <!-- Result card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="RESULT" Style="{StaticResource SectionLabel}" />
                            <local:MathMarkdownViewer Markdown="{Binding ResultText}"
                                                      FontSize="13"
                                                      Foreground="#DD1A1A1A" />
                        </StackPanel>
                    </Border>

                    <!-- Error + Retry card (conditional) -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding CanRetry, Converter={StaticResource BoolToVisibilityConverter}}"
                            BorderBrush="#55CC5555"
                            Background="#18FF4444">
                        <StackPanel>
                            <TextBlock Text="ERROR" Style="{StaticResource SectionLabel}" Foreground="#AACC2222" />
                            <TextBlock Text="{Binding ErrorText}"
                                       Margin="0,0,0,10"
                                       FontSize="13"
                                       Foreground="#CC8B1A1A"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                            <Button Content="Retry"
                                    Style="{StaticResource ActionButton}"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RetryCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Chat More -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CHAT MORE" Style="{StaticResource SectionLabel}" />

                            <ItemsControl ItemsSource="{Binding SuggestedPrompts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Margin="0,0,6,6"
                                                Padding="10,5"
                                                FontSize="12"
                                                Background="#22FFFFFF"
                                                BorderBrush="#33AAAAAA"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                Click="SuggestedPrompt_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Margin="0,4,0,8"
                                    Padding="8"
                                    CornerRadius="8"
                                    BorderBrush="#33BBBBBB"
                                    BorderThickness="1"
                                    Background="#1FFFFFFF">
                                <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChatTurns}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="8"
                                                        CornerRadius="7"
                                                        Background="#1AFFFFFF">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Prompt}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#CC1A1A1A"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Response}"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#AA000000"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"
                                         Padding="10,6"
                                         FontSize="12"
                                         Background="#22FFFFFF"
                                         BorderBrush="#44BBBBBB"
                                         BorderThickness="1"
                                         KeyDown="ChatInput_KeyDown" />
                                <Button Grid.Column="2"
                                        Content="Send"
                                        Style="{StaticResource ActionButton}"
                                        Command="{Binding SendChatCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
