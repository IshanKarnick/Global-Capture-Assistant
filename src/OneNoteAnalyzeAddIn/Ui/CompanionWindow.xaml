<Window x:Class="OneNoteAnalyzeAddIn.Ui.CompanionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:OneNoteAnalyzeAddIn.Ui.Converters"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Analyze Selection"
        Width="460"
        Height="760"
        MinWidth="380"
        MinHeight="540"
        WindowStartupLocation="Manual"
        Background="#131A24"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#C0202735" Offset="0" />
            <GradientStop Color="#AA151B26" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="Border" x:Key="GlassCard">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#3DFFFFFF" />
            <Setter Property="BorderBrush" Value="#4CFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource SidebarGradient}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Analyze Selection"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#FFF5F9FF" />
                <TextBlock Text="{Binding StatusText}"
                           Margin="0,4,0,0"
                           Foreground="#FFD7E7FF"
                           FontSize="13" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="Metadata"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF0A131F" />
                    <TextBlock Text="{Binding MetadataText}"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="#FF132439"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource GlassCard}"
                    Visibility="{Binding HasNotice, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding NoticeText}"
                           Foreground="#FF5A2A0A"
                           TextWrapping="Wrap" />
            </Border>

            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="Result"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF0A131F" />
                            <TextBlock Text="{Binding ResultText}"
                                       Margin="0,6,0,0"
                                       Foreground="#FF0D1D2E"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GlassCard}"
                            Visibility="{Binding CanRetry, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Error"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF5E1414" />
                            <TextBlock Text="{Binding ErrorText}"
                                       Margin="0,6,0,8"
                                       TextWrapping="Wrap"
                                       Foreground="#FF742323" />
                            <Button Content="Retry"
                                    Width="88"
                                    HorizontalAlignment="Left"
                                    Padding="10,6"
                                    Command="{Binding RetryCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="4" Style="{StaticResource GlassCard}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Recent Analyses"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF0A131F" />
                    <ItemsControl ItemsSource="{Binding History}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="8" CornerRadius="10" Background="#2FFFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                   Foreground="#A0192D47"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF0D1D2E"
                                                   Margin="0,2,0,2" />
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="#C0203149"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
